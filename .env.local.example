# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model (defaults to claude-opus-4-7)
# ANTHROPIC_MODEL=claude-opus-4-7

# Optional: Puppeteer Chromium path. Leave unset locally if puppeteer manages it.
# On Railway (Dockerfile), this is set to /usr/bin/chromium.
# PUPPETEER_EXECUTABLE_PATH=

# Shared secret required on POST /api/generate from cross-origin callers
# (e.g. the MVE service calling over the public internet). Same-origin
# requests from the admin form at `/` are always allowed.
# REQUIRED in production. If unset, the endpoint is open to anyone who
# discovers the URL — only acceptable for local dev.
# Generate one with: openssl rand -hex 32
PVRG_API_KEY=

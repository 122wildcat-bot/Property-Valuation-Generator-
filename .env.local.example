# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model (defaults to claude-opus-4-7)
# ANTHROPIC_MODEL=claude-opus-4-7

# Optional: Puppeteer Chromium path. Leave unset locally if puppeteer manages it.
# On Railway (Dockerfile), this is set to /usr/bin/chromium.
# PUPPETEER_EXECUTABLE_PATH=
